.PHONY : z80_opcodes.s

# target to generate assembly for a file
z80_opcodes.c.s:
	cd /Volumes/McFiver/u/GIT/ZX/NextPi/zxbasic-c/csrc/build-gcc && $(MAKE) $(MAKESILENT) -f zxbasm/CMakeFiles/zxbasm_lib.dir/build.make zxbasm/CMakeFiles/zxbasm_lib.dir/z80_opcodes.c.s
.PHONY : z80_opcodes.c.s

